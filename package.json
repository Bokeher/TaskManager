{
  "name": "taskmanager",
  "version": "0.9",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "start:client": "cd client && ng serve",
    "start:client-pl": "cd client && ng serve --configuration=pl-PL --open --port 4201",
    "start:client-cs": "cd client && ng serve --configuration=cs-CS --open --port 4202",
    "start:server": "cd server && node server.js",
    "start-pl": "concurrently \"npm run start:client-pl\" \"npm run start:server\"",
    "start-cs": "concurrently \"npm run start:client-cs\" \"npm run start:server\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install && cd ..",
    "extract-translation": "cd client && ng extract-i18n --output-path src/locale"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
